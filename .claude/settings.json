{
  "permissions": {
    "allow": [
      "Bash(python stepper/main.py*)",
      "Bash(pytest*)",
      "Bash(python -m pytest*)",
      "Bash(claude mcp *)",
      "mcp__playwright__browser_snapshot",
      "mcp__playwright__browser_navigate",
      "mcp__playwright__browser_click",
      "mcp__playwright__browser_fill_form",
      "mcp__playwright__browser_select_option",
      "mcp__playwright__browser_type",
      "mcp__playwright__browser_tabs"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/guard-dangerous-commands.js",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/post-edit-pom-check.js",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "node .claude/hooks/layer-boundary-reminder.js",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python .claude/hooks/pyright-check.py",
            "timeout": 30,
            "statusMessage": "Running Pyright..."
          }
        ]
      }
    ]
  }
}
