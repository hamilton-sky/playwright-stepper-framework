{
  "name": "Edge case: book already on shelf",
  "description": "Adds the same books twice — second pass must be idempotent (no duplicate, no crash)",
  "variables": {
    "query":    "Dune",
    "max_year": 1980,
    "limit":    2
  },
  "steps": [
    {
      "action": "ensure_login",
      "description": "Ensure user is logged in",
      "extra": {
        "check_url": "https://www.goodreads.com/review/list?shelf=want-to-read",
        "login_url_fragment": "/user/sign_in",
        "logged_in_selector": "a[href='/user/sign_out']",
        "login_steps": [
          { "action": "navigate", "url": "https://www.goodreads.com/user/sign_in" },
          { "action": "fill", "element": { "id": "user_email" }, "input_value": "ENV:GOODREADS_EMAIL" },
          { "action": "fill", "element": { "id": "user_password" }, "input_value": "ENV:GOODREADS_PASSWORD" },
          { "action": "click", "element": { "css": "input[name='next']" } }
        ]
      }
    },
    {
      "action": "gr_collect_items",
      "description": "Collect {{limit}} books (first pass)",
      "extra": {
        "query":    "{{query}}",
        "max_year": "{{max_year}}",
        "limit":    "{{limit}}"
      }
    },
    {
      "action": "gr_add_to_shelf",
      "description": "Add books — first pass",
      "extra": { "shelf": "want-to-read" }
    },
    {
      "action": "screenshot",
      "description": "Screenshot after first add",
      "extra": { "filename": "gr_edge_already_pass1.png" }
    },
    {
      "action": "gr_collect_items",
      "description": "Collect the same {{limit}} books again (second pass)",
      "extra": {
        "query":    "{{query}}",
        "max_year": "{{max_year}}",
        "limit":    "{{limit}}"
      }
    },
    {
      "action": "gr_add_to_shelf",
      "description": "Add same books again — must be idempotent",
      "extra": { "shelf": "want-to-read" }
    },
    {
      "action": "screenshot",
      "description": "Screenshot after second add — count must not have doubled",
      "extra": { "filename": "gr_edge_already_pass2.png" }
    }
  ]
}
