{
  "name": "Clear shelf then search and add books",
  "variables": {
    "query":    "Dune",
    "max_year": 1980,
    "limit":    5
  },
  "steps": [
    {
      "action": "run_workflow",
      "description": "Clear shelf first",
      "extra": { "path": "sites/goodreads/workflows/clear_shelf.json" }
    },
    {
      "action": "gr_collect_items",
      "description": "Collect {{limit}} {{query}} books published before {{max_year}}",
      "extra": {
        "query":    "{{query}}",
        "max_year": "{{max_year}}",
        "limit":    "{{limit}}"
      }
    },
    {
      "action": "gr_add_to_shelf",
      "description": "Add each collected book to want-to-read shelf",
      "extra": { "shelf": "want-to-read" }
    },
    {
      "action": "navigate",
      "description": "Open shelf to verify",
      "url": "https://www.goodreads.com/review/list?shelf=want-to-read"
    },
    {
      "action": "screenshot",
      "description": "Screenshot shelf after add",
      "extra": { "filename": "gr_shelf_after_clear_add.png" }
    }
  ]
}
