{
  "name": "Search and add books to Goodreads shelf",
  "variables": {
    "query":    "Dune",
    "max_year": 1980,
    "limit":    5
  },
  "steps": [
    {
      "action": "ensure_login",
      "description": "Ensure user is logged in",
      "extra": {
        "check_url": "https://www.goodreads.com/review/list?shelf=want-to-read",
        "login_url_fragment": "/user/sign_in",
        "logged_in_selector": "a[href='/user/sign_out']",
        "login_steps": [
          {
            "action": "navigate",
            "description": "Open sign-in page",
            "url": "https://www.goodreads.com/user/sign_in"
          },
          {
            "action": "fill",
            "description": "Fill email",
            "element": { "id": "user_email" },
            "input_value": "ENV:GOODREADS_EMAIL"
          },
          {
            "action": "fill",
            "description": "Fill password",
            "element": { "id": "user_password" },
            "input_value": "ENV:GOODREADS_PASSWORD"
          },
          {
            "action": "click",
            "description": "Submit sign-in form",
            "element": { "css": "input[name='next']" }
          }
        ]
      }
    },
    {
      "action": "gr_collect_items",
      "description": "Collect {{limit}} {{query}} books published before {{max_year}}",
      "extra": {
        "query":    "{{query}}",
        "max_year": "{{max_year}}",
        "limit":    "{{limit}}"
      }
    },
    {
      "action": "gr_add_to_shelf",
      "description": "Add each collected book to want-to-read shelf",
      "extra": {
        "shelf": "want-to-read"
      }
    },
    {
      "action": "screenshot",
      "description": "Screenshot shelf after adding books",
      "extra": { "filename": "gr_shelf_after_add.png" }
    }
  ]
}
