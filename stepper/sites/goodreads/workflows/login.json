{
  "name": "Ensure Goodreads login",
  "steps": [
    {
      "action": "ensure_login",
      "description": "Ensure user is logged in to Goodreads",
      "extra": {
        "check_url": "https://www.goodreads.com/review/list?shelf=want-to-read",
        "login_url_fragment": "/user/sign_in",
        "logged_in_selector": "a[href='/user/sign_out']",
        "login_steps": [
          {
            "action": "navigate",
            "description": "Open sign-in page",
            "url": "https://www.goodreads.com/user/sign_in"
          },
          {
            "action": "fill",
            "description": "Fill email",
            "element": { "id": "user_email" },
            "input_value": "ENV:GOODREADS_EMAIL"
          },
          {
            "action": "fill",
            "description": "Fill password",
            "element": { "id": "user_password" },
            "input_value": "ENV:GOODREADS_PASSWORD"
          },
          {
            "action": "click",
            "description": "Submit sign-in form",
            "element": { "css": "input[name='next']" }
          }
        ]
      }
    }
  ]
}
