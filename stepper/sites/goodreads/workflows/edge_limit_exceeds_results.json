{
  "name": "Edge case: limit exceeds available search results",
  "description": "Requests more books than the search returns — should collect all available without error",
  "variables": {
    "query":    "very obscure book title xyz",
    "max_year": 2000,
    "limit":    50
  },
  "steps": [
    {
      "action": "ensure_login",
      "description": "Ensure user is logged in",
      "extra": {
        "check_url": "https://www.goodreads.com/review/list?shelf=want-to-read",
        "login_url_fragment": "/user/sign_in",
        "logged_in_selector": "a[href='/user/sign_out']",
        "login_steps": [
          { "action": "navigate", "url": "https://www.goodreads.com/user/sign_in" },
          { "action": "fill", "element": { "id": "user_email" }, "input_value": "ENV:GOODREADS_EMAIL" },
          { "action": "fill", "element": { "id": "user_password" }, "input_value": "ENV:GOODREADS_PASSWORD" },
          { "action": "click", "element": { "css": "input[name='next']" } }
        ]
      }
    },
    {
      "action": "gr_collect_items",
      "description": "Attempt to collect {{limit}} books (more than results available)",
      "extra": {
        "query":    "{{query}}",
        "max_year": "{{max_year}}",
        "limit":    "{{limit}}"
      }
    },
    {
      "action": "screenshot",
      "description": "Screenshot collected results (fewer than limit)",
      "extra": { "filename": "gr_edge_limit_exceeds.png" }
    }
  ]
}
