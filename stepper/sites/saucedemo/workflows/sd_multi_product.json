{
  "name": "SauceDemo — collect, filter, add to cart, checkout",
  "description": "Sort by price, collect products under a price cap, add them to cart, verify count, then complete checkout.",
  "variables": {
    "price_max":  18,
    "limit":       3,
    "first_name": "Jane",
    "last_name":  "Doe",
    "zip":        "90210"
  },
  "steps": [
    {
      "action": "sd_login",
      "description": "Log in with standard_user credentials",
      "continue_on_failure": false
    },
    {
      "action": "sd_sort_products",
      "description": "Sort products by price — low to high",
      "extra": { "sort": "lohi" }
    },
    {
      "action": "sd_collect_products",
      "description": "Collect up to {{limit}} products priced under ${{price_max}}",
      "extra": {
        "filter": { "price_max": "{{price_max}}" },
        "limit":  "{{limit}}"
      }
    },
    {
      "action": "sd_add_to_cart",
      "description": "Add all collected products to the cart"
    },
    {
      "action": "sd_view_cart",
      "description": "Navigate to cart — store item count in context",
      "continue_on_failure": false
    },
    {
      "action": "assert_count",
      "description": "Assert cart contains exactly {{limit}} items",
      "extra": {
        "selectors": [".cart_item"],
        "expected":  "{{limit}}"
      }
    },
    {
      "action": "screenshot",
      "description": "Capture cart with collected products",
      "extra": { "filename": "multi_product_cart.png" }
    },
    {
      "action": "sd_checkout",
      "description": "Complete checkout — verify order confirmation",
      "extra": {
        "first_name": "{{first_name}}",
        "last_name":  "{{last_name}}",
        "zip":        "{{zip}}"
      }
    },
    {
      "action": "screenshot",
      "description": "Capture order confirmation screen",
      "extra": { "filename": "multi_product_confirmation.png" }
    }
  ]
}
