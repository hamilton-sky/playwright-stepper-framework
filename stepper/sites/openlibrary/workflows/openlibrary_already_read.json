{
  "name": "Search and mark books as Already Read",
  "description": "Different scenario on OpenLibrary — search classic sci-fi, add to Already Read shelf instead of Want to Read",
  "steps": [
    {
      "action": "run_workflow",
      "description": "Ensure user is logged in (subflow)",
      "extra": { "path": "login.json" }
    },
    {
      "action": "store_count",
      "description": "Capture already-read count before adding",
      "extra": {
        "selectors": ["ul.list-books > li"],
        "context_key": "count_before"
      }
    },
    {
      "action": "collect_items",
      "description": "Collect 3 Asimov books published before 1970",
      "extra": {
        "query": "Isaac Asimov",
        "filter": { "year_max": 1970 },
        "limit": 3
      }
    },
    {
      "action": "for_each_item",
      "description": "Mark each book as Already Read",
      "extra": {
        "steps": [
          {
            "action": "navigate",
            "description": "Open book {{index}}",
            "url": "{{item_url}}"
          },
          {
            "action": "click",
            "description": "Open shelf dropdown (unactivated button only)",
            "element": { "css": "button.book-progress-btn.unactivated" },
            "when": { "element_exists": "button.book-progress-btn.unactivated" }
          },
          {
            "action": "click",
            "description": "Click Already Read in dropdown",
            "element": { "text": "Already Read" },
            "when": { "element_exists": ".read-options" }
          },
          {
            "action": "screenshot",
            "description": "Screenshot after marking book {{index}}",
            "extra": { "filename": "already_read_{{index}}.png" }
          }
        ]
      }
    },
    {
      "action": "navigate",
      "description": "Open already-read list",
      "url": "https://openlibrary.org/account/books/already-read"
    },
    {
      "action": "screenshot",
      "description": "Screenshot of already-read shelf",
      "extra": { "filename": "already_read_shelf.png" }
    }
  ]
}
