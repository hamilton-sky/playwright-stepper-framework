{
  "name": "Clear reading list, then search and add Dune books",
  "steps": [
    {
      "action": "run_workflow",
      "description": "Ensure user is logged in (subflow)",
      "extra": { "path": "login.json" }
    },
    {
      "action": "navigate",
      "description": "Open want-to-read list",
      "url": "https://openlibrary.org/account/books/want-to-read"
    },
    {
      "action": "extract_data",
      "description": "Collect all book URLs from reading list",
      "extra": {
        "selector": "ul.list-books li a[href*='/works/']",
        "attrs": ["href"],
        "context_key": "collected_items",
        "url_prefix": "https://openlibrary.org",
        "wait_for_state": "attached",
        "limit": 500,
        "allow_empty": true
      }
    },
    {
      "action": "for_each_item",
      "description": "Navigate to each book and toggle it off the shelf",
      "extra": {
        "steps": [
          {
            "action": "navigate",
            "description": "Open book {{index}}",
            "url": "{{item_url}}"
          },
          {
            "action": "click",
            "description": "Open shelf dropdown",
            "element": { "css": "button.book-progress-btn" }
          },
          {
            "action": "click",
            "description": "Click Remove From Shelf via JS (bypasses hidden class)",
            "element": { "css": "button.remove-from-list" },
            "js_click": true
          },
          {
            "action": "screenshot",
            "description": "Screenshot after removing book {{index}}",
            "extra": { "filename": "removed_{{index}}.png" }
          }
        ]
      }
    },
    {
      "action": "navigate",
      "description": "Return to reading list to verify empty",
      "url": "https://openlibrary.org/account/books/want-to-read"
    },
    {
      "action": "screenshot",
      "description": "Screenshot empty reading list",
      "extra": { "filename": "reading_list_cleared.png" }
    },
    {
      "action": "store_count",
      "description": "Store reading list count before adding",
      "extra": {
        "selectors": ["ul.list-books > li"],
        "context_key": "count_before"
      }
    },
    {
      "action": "collect_items",
      "description": "Collect 5 Dune books published before 1980",
      "extra": {
        "filter": { "year_max": 1980 },
        "limit": 5,
        "query": "Dune",
        "base_url": "https://openlibrary.org"
      }
    },
    {
      "action": "for_each_item",
      "description": "Add each book to reading list",
      "extra": {
        "steps": [
          {
            "action": "navigate",
            "description": "Open book {{index}}",
            "url": "{{item_url}}"
          },
          {
            "action": "click",
            "description": "Click shelf button",
            "element": {
              "css": "button.book-progress-btn.unactivated, button.book-progress-btn.primary-action"
            }
          },
          {
            "action": "screenshot",
            "description": "Screenshot book {{index}}",
            "extra": { "filename": "book_{{index}}.png" }
          }
        ]
      }
    },
    {
      "action": "ol_assert_count",
      "description": "Assert reading list count increased by 5",
      "extra": {
        "delta": 5
      }
    }
  ]
}
