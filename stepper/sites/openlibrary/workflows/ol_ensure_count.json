{
  "name": "OpenLibrary — ensure reading list has exactly N books (top-up)",
  "description": "Check current count. If already at target, all downstream steps skip automatically via when-guards. Otherwise collect exactly the gap, add to shelf, and verify.",
  "variables": {
    "target_count": 5,
    "query":        "Dune",
    "max_year":     1980
  },
  "steps": [
    {
      "action": "ol_ensure_login",
      "description": "Ensure user is logged in"
    },
    {
      "action": "ol_ensure_count",
      "description": "Check shelf count — store gap in context if top-up needed",
      "extra": {
        "target_count": "{{target_count}}"
      }
    },
    {
      "action": "ol_collect_books",
      "description": "Collect exactly gap books",
      "when": { "context_greater_than": { "key": "gap", "value": 0 } },
      "extra": {
        "query":  "{{query}}",
        "filter": { "year_max": "{{max_year}}" },
        "limit":  "{{gap}}"
      }
    },
    {
      "action": "ol_add_to_shelf",
      "description": "Add collected books to shelf",
      "when": { "context_key_exists": "collected_items" }
    },
    {
      "action": "ol_assert_count",
      "description": "Verify shelf count equals target after top-up",
      "when": { "context_greater_than": { "key": "gap", "value": 0 } },
      "extra": {
        "expected_count": "{{target_count}}"
      }
    }
  ]
}
