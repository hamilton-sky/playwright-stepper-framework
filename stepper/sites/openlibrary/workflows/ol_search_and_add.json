{
  "name": "OpenLibrary — clear, search, add to shelf, assert (page module workflow)",
  "variables": {
    "query":    "Dune",
    "max_year": 1980,
    "limit":    5
  },
  "steps": [
    {
      "action": "ol_ensure_login",
      "description": "Ensure user is logged in"
    },
    { "action": "screenshot",
      "description": "Capture logged-in state"
    },
    {
      "action": "ol_clear_reading_list",
      "description": "Remove all books from want-to-read shelf"
    },
    {
      "action": "ol_store_count",
      "description": "Store reading list count (should be 0 after clear)",
      "extra": { "context_key": "count_before" }
    },
    {
      "action": "ol_collect_books",
      "description": "Search and collect {{limit}} {{query}} books published before {{max_year}}",
      "extra": {
        "query": "{{query}}",
        "filter": { "year_max": "{{max_year}}" },
        "limit": "{{limit}}"
      }
    },
    {
      "action": "ol_add_to_shelf",
      "description": "Add each collected book to reading list + screenshot"
    },
    {
      "action": "ol_assert_count",
      "description": "Assert reading list count increased by {{limit}}",
      "extra": { "delta": "{{limit}}" }
    }
  ]
}
