{
  "name": "Search and add books to reading list",
  "variables": {
    "query":    "Dune",
    "max_year": 1980,
    "limit":    5
  },
  "steps": [
    {
      "action": "run_workflow",
      "description": "Ensure user is logged in (subflow)",
      "extra": { "path": "login.json" }
    },
    {
      "action": "navigate",
      "description": "Open want-to-read list",
      "url": "https://openlibrary.org/account/books/want-to-read"
    },
    {
      "action": "extract_data",
      "description": "Collect existing book URLs to clear",
      "extra": {
        "selector": "ul.list-books li a[href*='/works/']",
        "attrs": ["href"],
        "context_key": "collected_items",
        "url_prefix": "https://openlibrary.org",
        "limit": 500,
        "allow_empty": true
      }
    },
    {
      "action": "for_each_item",
      "description": "Remove each existing book from shelf",
      "extra": {
        "steps": [
          { "action": "navigate", "description": "Open book {{index}}", "url": "{{item_url}}" },
          {
            "action": "click",
            "description": "Open shelf dropdown",
            "element": { "role": "button", "name": "Want to Read" }
          },
          {
            "action": "click",
            "description": "Remove from shelf",
            "element": { "css": "button.remove-from-list" },
            "js_click": true
          }
        ]
      }
    },
    {
      "action": "store_count",
      "description": "Store reading list count before adding (should be 0)",
      "extra": {
        "selectors": ["ul.list-books > li"],
        "context_key": "count_before"
      }
    },
    {
      "action": "collect_items",
      "description": "Collect {{limit}} {{query}} books published before {{max_year}}",
      "extra": {
        "filter": { "year_max": "{{max_year}}" },
        "limit": "{{limit}}",
        "query": "{{query}}",
        "base_url": "https://openlibrary.org"
      }
    },
    {
      "action": "for_each_item",
      "description": "Add each book to reading list",
      "extra": {
        "steps": [
          {
            "action": "navigate",
            "description": "Open book {{index}}",
            "url": "{{item_url}}"
          },
          {
            "action": "click",
            "description": "Click shelf button to add book",
            "element": { "role": "button", "name": "Want to Read" },
            "when": { "element_exists": "button.book-progress-btn.unactivated" }
          },
          {
            "action": "screenshot",
            "description": "Screenshot book {{index}}",
            "extra": { "filename": "book_{{index}}.png" }
          }
        ]
      }
    },
    {
      "action": "navigate",
      "description": "Open want-to-read list",
      "url": "https://openlibrary.org/account/books/want-to-read"
    },
    {
      "action": "ol_assert_count",
      "description": "Assert reading list count increased by {{limit}}",
      "extra": {
        "delta": "{{limit}}"
      }
    }
  ]
}
