{
  "name": "Edge case — add books already on shelf (idempotency)",
  "description": "Run search_and_add twice in a row without clearing. Second run should skip all adds gracefully (when guard) and assert count stays the same.",
  "steps": [
    {
      "action": "run_workflow",
      "description": "Ensure user is logged in (subflow)",
      "extra": { "path": "login.json" }
    },
    {
      "action": "navigate",
      "description": "Open want-to-read list",
      "url": "https://openlibrary.org/account/books/want-to-read"
    },
    {
      "action": "extract_data",
      "description": "Collect existing book URLs to clear",
      "extra": {
        "selector": "ul.list-books li a[href*='/works/']",
        "attrs": ["href"],
        "context_key": "collected_items",
        "url_prefix": "https://openlibrary.org",
        "limit": 500,
        "allow_empty": true
      }
    },
    {
      "action": "for_each_item",
      "description": "Clear reading list",
      "extra": {
        "steps": [
          { "action": "navigate", "description": "Open book {{index}}", "url": "{{item_url}}" },
          { "action": "click",    "description": "Open shelf dropdown", "element": { "css": "button.book-progress-btn" } },
          { "action": "click",    "description": "Remove from shelf",   "element": { "css": "button.remove-from-list" }, "js_click": true }
        ]
      }
    },
    {
      "action": "ol_collect_books",
      "description": "Collect 3 Dune books",
      "extra": {
        "query": "Dune",
        "filter": { "year_max": 1980 },
        "limit": 3
      }
    },
    {
      "action": "ol_add_to_shelf",
      "description": "First add — books are not on shelf yet"
    },
    {
      "action": "screenshot",
      "description": "Screenshot after first add",
      "extra": { "filename": "idempotent_after_first_add.png" }
    },
    {
      "action": "ol_collect_books",
      "description": "Collect the same 3 Dune books again",
      "extra": {
        "query": "Dune",
        "filter": { "year_max": 1980 },
        "limit": 3
      }
    },
    {
      "action": "ol_add_to_shelf",
      "description": "Second add — books already on shelf, should all be skipped gracefully"
    },
    {
      "action": "screenshot",
      "description": "Screenshot after second add — count must not have doubled",
      "extra": { "filename": "idempotent_after_second_add.png" }
    },
    {
      "action": "ol_assert_count",
      "description": "Assert reading list still has exactly 3 books (not 6)",
      "extra": {
        "expected_count": 3
      }
    }
  ]
}
